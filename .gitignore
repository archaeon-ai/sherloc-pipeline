# BUT allow test fixtures (override the above)
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.png
!tests/fixtures/**/*.CSV
!tests/fixtures/**/*.PNG

# Package-data shipped inside the wheel (issue #13 — background CSVs).
# The `data/` and `*.csv` rules above are scoped to the SHERLOC data-lake
# layout; package-resource directories under src/sherloc_pipeline/ are
# product code, not data-lake artifacts. Narrowly carve out the directory
# entry + __init__.py + concrete asset types (no blanket `**`, which
# would re-include __pycache__).
!src/sherloc_pipeline/data/
!src/sherloc_pipeline/data/**/__init__.py
!src/sherloc_pipeline/data/**/*.csv

# Ignore generated metadata JSON in pipeline outputs (timestamps cause spurious diffs)
tests/fixtures/pipeline_outputs/**/*.json

# preprocessing.py auto-emits a diagnostic plot next to the background CSV
# whenever the background subtraction step runs. Under SHERLOC_BACKGROUND_DIR
# this lands inside tests/fixtures/background/ — diagnostic-only, not a
# fixture, so keep it out of git.
tests/fixtures/background/*.png
config/local.yaml

