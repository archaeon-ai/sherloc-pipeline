# sherloc.env.example — Reference env-var shape for SHERLOC backend.
# See DEPLOYMENT_CONTRACT.md §5 for the authoritative variable surface.
# Required vars are marked REQ. Replace `change-me-*` with your values.

# ----- Auth mode (default cf-access; auth0 is production) ------------------
# auth0     → production tier with Auth0 JWT validation
# cf-access → legacy Cloudflare Access JWT validation
# dev       → localhost-only, no auth (DO NOT use in production)
SHERLOC_AUTH_MODE=auth0   # REQ if you change the default

# ----- Auth0 mode (required when SHERLOC_AUTH_MODE=auth0) ------------------
SHERLOC_AUTH0_DOMAIN=change-me.auth0.com                                  # REQ
SHERLOC_AUTH0_AUDIENCE=https://api.example.com                            # REQ
SHERLOC_AUTH0_SPA_CLIENT_ID=change-me-spa-client-id                       # REQ
SHERLOC_AUTH0_IDENTITY_CLAIM_URI=https://example.com/claims/identity      # REQ; namespace URI

# Optional Auth0 tunables (defaults shown):
#SHERLOC_AUTH0_JWKS_TTL_SECONDS=600
#SHERLOC_AUTH0_JWKS_MAX_STALE_SECONDS=86400
#SHERLOC_AUTH0_EXPECTED_AZP=                # Single-SPA azp pin (set this OR _KNOWN_SPA_CLIENT_IDS)
#SHERLOC_AUTH0_KNOWN_SPA_CLIENT_IDS=        # CSV; mutually exclusive with EXPECTED_AZP
#SHERLOC_AUTH_REALM=m2020-phase             # WWW-Authenticate realm

# ----- CF-Access mode (required when SHERLOC_AUTH_MODE=cf-access) ----------
#SHERLOC_CF_TEAM_DOMAIN=yourteam.cloudflareaccess.com
#SHERLOC_CF_AUDIENCE=change-me-app-aud

# ----- Storage (always required) -------------------------------------------
SHERLOC_DB=/data/phase.db              # REQ; container-internal path
# PHASE_DATABASE_PATH is an optional legacy alias. The entrypoint exports
# it from SHERLOC_DB when unset. If you set it explicitly, it MUST equal
# SHERLOC_DB or config_check exits 1 with a `differ` error. See
# DEPLOYMENT_CONTRACT.md §5.1.
#PHASE_DATABASE_PATH=/data/phase.db

# ----- Access mode (optional; default internal) ----------------------------
# internal → require team-member identity claim on every data-bearing route
# public   → no role requirement (any valid JWT)
# Public mode REQUIRES SHERLOC_DB filename to contain `phase_pds.db`.
SHERLOC_ACCESS_MODE=internal

# ----- S3-Compatible Object Storage (required when SHERLOC_AUTH_MODE=auth0) ----
# Primary deploy target is Cloudflare R2; any S3-compatible store with the
# same AWS-style env vars works. The production deploy uses R2-bucket-scoped
# slot credentials so a cross-tier credential leak is caught at the bucket layer.
PHASE_TIER=team                                    # REQ; team | public
AWS_ACCESS_KEY_ID=change-me                        # REQ
AWS_SECRET_ACCESS_KEY=change-me                    # REQ
AWS_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com   # REQ
AWS_REGION=auto                                    # optional; default 'auto'

# Optional legacy `file_path` prefix aliases. Colon-separated ($PATH-style)
# list of additional prefixes accepted alongside the canonical strip prefix
# (PHASE_{TEAM,PUBLIC}_STRIP_PREFIX). Additive: the in-tree built-in default
# for the team tier stays in scope regardless of this setting. Use to onboard
# additional deployment-specific legacy ingestion roots without a code change.
# Alias values containing a literal `:` are unsupported. v4.1.17+.
# See DEPLOYMENT_CONTRACT.md §5.4.
#PHASE_TEAM_LEGACY_STRIP_ALIASES=/some/legacy/root/:/another/root/
#PHASE_PUBLIC_LEGACY_STRIP_ALIASES=

# ----- Observability (optional) --------------------------------------------
#SHERLOC_LOG_LEVEL=INFO

# ----- CORS (optional) -----------------------------------------------------
#SHERLOC_CORS_ALLOWED_ORIGINS=https://your-spa.example.com

# ----- Feature flags -------------------------------------------------------
# Only the literal value `disabled` (case-insensitive) hides the PDS Browser tab.
#SHERLOC_FEATURE_PDS_BROWSER=disabled

# Retired variables (see DEPLOYMENT_CONTRACT.md §5.5) MUST NOT appear in
# this template — neither as assignments nor commented assignments nor
# names in a "do not add" block. The contract test asserts literal
# absence; do not list the retired names anywhere in this file.
